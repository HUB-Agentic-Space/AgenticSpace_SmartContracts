{
  "name": "@agentic-space/smartcontracts",
  "version": "0.1.0",
  "description": "Smart Contracts do Agentic Space - Solidity + Hardhat + Foundry",
  "license": "CC-BY-SA-4.0",
  "private": true,
  "scripts": {
    "compile": "hardhat compile",
    "clean": "hardhat clean",
    "test": "hardhat test",
    "test:foundry": "forge test",
    "test:coverage": "hardhat coverage",
    "typechain": "hardhat typechain",
    "deploy:amoy": "hardhat run scripts/deploy/00_deploy_diamond.ts --network polygonAmoy",
    "deploy:polygon": "hardhat run scripts/deploy/00_deploy_diamond.ts --network polygon",
    "deploy:tokens:amoy": "hardhat run scripts/deploy/01_deploy_tokens.ts --network polygonAmoy",
    "deploy:tokens:polygon": "hardhat run scripts/deploy/01_deploy_tokens.ts --network polygon",
    "deploy:swap:amoy": "hardhat run scripts/deploy/03_deploy_cas_swap.ts --network polygonAmoy",
    "deploy:swap:polygon": "hardhat run scripts/deploy/03_deploy_cas_swap.ts --network polygon",
    "deploy:dex:polygon": "hardhat run scripts/deploy/04_add_dex_liquidity.ts --network polygon",
    "deploy:lock:polygon": "hardhat run scripts/deploy/05_lock_liquidity.ts --network polygon",
    "deploy:multisig:amoy": "hardhat run scripts/deploy/06_transfer_to_multisig.ts --network polygonAmoy",
    "deploy:multisig:polygon": "hardhat run scripts/deploy/06_transfer_to_multisig.ts --network polygon",
    "validate:amoy": "hardhat run scripts/utils/validate_amoy.ts --network polygonAmoy",
    "deploy:faucet:amoy": "hardhat run scripts/deploy/02_deploy_faucet.ts --network polygonAmoy",
    "deploy:faucet:polygon": "hardhat run scripts/deploy/02_deploy_faucet.ts --network polygon",
    "deploy:certificate:amoy": "hardhat run scripts/deploy/12_deploy_rapport_certificate.ts --network polygonAmoy",
    "deploy:certificate:polygon": "hardhat run scripts/deploy/12_deploy_rapport_certificate.ts --network polygon",
    "register:certificate-fee:amoy": "hardhat run scripts/deploy/13_register_certificate_fee.ts --network polygonAmoy",
    "register:certificate-fee:polygon": "hardhat run scripts/deploy/13_register_certificate_fee.ts --network polygon",
    "register:certificate:diamond:amoy": "hardhat run scripts/deploy/14_register_rapport_certificate.ts --network polygonAmoy",
    "register:certificate:diamond:polygon": "hardhat run scripts/deploy/14_register_rapport_certificate.ts --network polygon",
    "finalize:certificate-roles:amoy": "hardhat run scripts/deploy/15_finalize_rapport_certificate_roles.ts --network polygonAmoy",
    "finalize:certificate-roles:polygon": "hardhat run scripts/deploy/15_finalize_rapport_certificate_roles.ts --network polygon",
    "smoke:certificate:polygon-fork": "hardhat run scripts/utils/smoke_certificate_polygon_fork.ts",
    "faucet:test:amoy": "hardhat run scripts/utils/faucet_test.ts --network polygonAmoy",
    "faucet:test:polygon": "hardhat run scripts/utils/faucet_test.ts --network polygon",
    "verify": "hardhat verify --network polygonAmoy --list",
    "upgrade": "hardhat run scripts/utils/upgrade_contract.ts",
    "setup-relayer:amoy": "hardhat run scripts/utils/setup_relayer.ts --network polygonAmoy",
    "setup-relayer:polygon": "hardhat run scripts/utils/setup_relayer.ts --network polygon",
    "audit:slither": "bash scripts/audit/slither_analyze.sh",
    "audit:mythril": "bash scripts/audit/mythril_analyze.sh",
    "audit:solhint": "solhint 'contracts/**/*.sol'",
    "audit:echidna": "bash scripts/audit/echidna_fuzz.sh",
    "audit:full": "npm run audit:solhint && npm run audit:slither && npm run audit:mythril && npm run audit:echidna",
    "analyze:gas": "hardhat test --network hardhat --grep 'GasReport' && bash scripts/analysis/gas_report.sh",
    "analyze:size": "bash scripts/analysis/contract_size.sh",
    "analyze:coverage": "hardhat coverage && bash scripts/analysis/coverage_report.sh",
    "analysis:cas:distribution": "hardhat run scripts/analysis/cas_distribution_dashboard.ts",
    "distribute:cas:polygon": "hardhat run scripts/casswap/06_redistribute_cas.ts --network polygon",
    "restore:ratio:polygon": "hardhat run scripts/casswap/07_check_and_restore_ratio.ts --network polygon",
    "sync:cas:db": "hardhat run scripts/casswap/08_sync_cas_db.ts --network polygon",
    "cas:db": "tsx scripts/casswap/09_cas_db_cli.ts",
    "cas:db:label": "tsx scripts/casswap/09_cas_db_cli.ts label",
    "cas:db:list": "tsx scripts/casswap/09_cas_db_cli.ts list",
    "cas:db:stats": "tsx scripts/casswap/09_cas_db_cli.ts stats",
    "cas:db:txs": "tsx scripts/casswap/09_cas_db_cli.ts txs",
    "cas:db:search": "tsx scripts/casswap/09_cas_db_cli.ts search",
    "cas:label": "tsx scripts/casswap/10_label_address.ts"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@openzeppelin/contracts-upgradeable": "^5.0.2",
    "@openzeppelin/hardhat-upgrades": "^3.2.0",
    "@typechain/hardhat": "^9.1.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/ink": "0.5.2",
    "@types/node": "^22.0.0",
    "@types/react": "18.3.31",
    "dotenv": "^16.4.0",
    "hardhat": "^2.22.0",
    "ink": "5.2.1",
    "react": "18.3.1",
    "solhint": "^5.0.0",
    "ts-node": "^10.9.0",
    "tsx": "4.23.1",
    "typechain": "^8.3.0",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1"
  }
}
